{
  "name": "mytng-compiler-monorepo",
  "description": "The Mytng Compiler",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.7.0",
  "engines": {
    "node": ">=24.16.0"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "run-s dev-play dev-watch",
    "dev-play": "pnpm pack-build && pnpm run --filter='./apps/dev-playground' dev",
    "dev-watch": "tsdown --watch",
    "dev-build": "pnpm run build && pnpm run --filter='./apps/dev-playground' build",
    "test": "vitest",
    "test-unit": "vitest --project unit*",
    "test-e2e": "vitest --project e2e",
    "test-coverage": "vitest --ui --project unit* --coverage.enabled=true",
    "bench": "vitest bench --project=unit --outputJson=temp/bench.json",
    "bench-compare": "vitest bench --project=unit --compare=temp/bench.json",
    "lint": "oxlint",
    "format": "oxfmt",
    "format-check": "oxfmt --check",
    "format:toml": "taplo format",
    "format:rs": "cargo fmt",
    "format:all": "run-p format format:rs format:toml",
    "clean": "rimraf --glob packages/*/dist temp",
    "check": "pnpm tsc --incremental --noEmit",
    "build": "pnpm check && pnpm pack-build",
    "build:compiler": "pnpm --filter @mytng/compiler run build",
    "pack-build": "tsdown --tsconfig tsconfig.build.json && rimraf --glob 'packages/*/dist/*-browser.d.ts'",
    "preinstall": "npx only-allow pnpm",
    "postinstall": "simple-git-hooks"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged && pnpm check",
    "commit-msg": "node scripts/verify-commit.mjs"
  },
  "lint-staged": {
    "*.{js,mjs,json}": [
      "oxfmt --no-error-on-unmatched-pattern"
    ],
    "*.{ts,tsx}": [
      "oxlint --fix",
      "oxfmt --no-error-on-unmatched-pattern"
    ],
    "*.toml": [
      "taplo format"
    ]
  },
  "devDependencies": {
    "@changesets/changelog-github": "catalog:",
    "@changesets/cli": "catalog:",
    "@tailwindcss/postcss": "catalog:",
    "@tailwindcss/vite": "catalog:",
    "@taplo/cli": "^0.7.0",
    "@types/node": "^25.9.3",
    "@vitest/browser-playwright": "^4.1.9",
    "@vitest/coverage-v8": "^4.1.9",
    "@vitest/ui": "^4.1.9",
    "chalk": "^5.6.2",
    "lint-staged": "^17.0.7",
    "npm-run-all2": "^9.0.2",
    "oxfmt": "^0.55.0",
    "oxlint": "^1.70.0",
    "postcss": "catalog:",
    "puppeteer": "^25.1.0",
    "rimraf": "^6.1.3",
    "simple-git-hooks": "^2.13.1",
    "tailwindcss": "catalog:",
    "tinyglobby": "^0.2.17",
    "tsdown": "^0.22.3",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vitest": "^4.1.9"
  }
}
