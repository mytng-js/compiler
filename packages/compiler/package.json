{
  "name": "@mytng/compiler",
  "version": "0.0.0",
  "description": "Mytng compiler",
  "type": "module",
  "main": "index.js",
  "types": "index.d.ts",
  "browser": "browser.js",
  "files": [
    "index.d.ts",
    "index.js",
    "browser.js"
  ],
  "scripts": {
    "artifacts": "napi artifacts",
    "build": "napi build --platform --release",
    "dev": "nodemon -w crates -e rs -x 'napi build --platform'",
    "prepublishOnly": "napi prepublish -t npm",
    "version": "napi version",
    "test": "cargo test -- --nocapture",
    "test:watch": "nodemon -w crates -w tests -w src -e rs -x 'cargo test'"
  },
  "devDependencies": {
    "@emnapi/core": "^1.11.1",
    "@emnapi/runtime": "^1.11.1",
    "@napi-rs/cli": "^3.7.2",
    "@napi-rs/wasm-runtime": "^1.1.5",
    "@tybys/wasm-util": "^0.10.2"
  },
  "napi": {
    "binaryName": "compiler",
    "targets": [
      "x86_64-pc-windows-msvc",
      "x86_64-apple-darwin",
      "x86_64-unknown-linux-gnu",
      "x86_64-unknown-linux-musl",
      "aarch64-unknown-linux-gnu",
      "aarch64-apple-darwin",
      "aarch64-unknown-linux-musl",
      "aarch64-pc-windows-msvc",
      "wasm32-wasip1-threads"
    ]
  },
  "keywords": [
    "myt",
    "mytng",
    "compiler",
    "napi-rs",
    "NAPI",
    "N-API",
    "Rust",
    "node-addon",
    "node-addon-api"
  ],
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mytng-js/compiler.git",
    "directory": "packages/compiler"
  },
  "bugs": {
    "url": "https://github.com/mytng-js/compiler/issues"
  },
  "homepage": "https://github.com/mytng-js/compiler",
  "license": "MIT"
}
